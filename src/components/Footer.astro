---
// Footer.astro
---
<footer class="bg-primary-black text-light-silver py-8 mt-auto font-inter text-sm">
  <div class="max-w-7xl mx-auto px-6 grid grid-cols-1 md:grid-cols-3 gap-8 text-center md:text-left">
    <!-- About / Copyright -->
    <div>
      <h3 class="text-xl font-oswald text-white mb-4">SCVDA</h3>
      <p class="mb-4">Santa Clara Valley Darts Association</p>
      <p>Material Copyright 1998-2026 Santa Clara Valley Darts Association</p>
    </div>

    <!-- Contact Info Placeholder -->
    <div>
      <h3 class="text-xl font-oswald text-white mb-4">Contact Us</h3>
      <ul class="space-y-2">
        <li>Email: info@scvda.com</li>
        <li>Phone: (123) 456-7890</li>
        <li>Address: Santa Clara Valley, CA</li>
      </ul>
    </div>

    <!-- Social Media -->
    <div>
      <h3 class="text-xl font-oswald text-white mb-4">Follow Us</h3>
      <div class="flex justify-center md:justify-start space-x-4">
        <a href="https://www.facebook.com/SCVDA" target="_blank" rel="noopener noreferrer" class="w-8 h-8 rounded-full bg-light-silver text-primary-black flex items-center justify-center hover:bg-accent-red hover:text-white transition-colors" aria-label="Facebook">
          <i class="fa-brands fa-facebook-f"></i>
        </a>
        <a href="https://www.instagram.com/scvdadarts" target="_blank" rel="noopener noreferrer" class="w-8 h-8 rounded-full bg-light-silver text-primary-black flex items-center justify-center hover:bg-accent-red hover:text-white transition-colors" aria-label="Instagram">
          <i class="fa-brands fa-instagram"></i>
        </a>
      </div>
    </div>
  </div>
</footer>