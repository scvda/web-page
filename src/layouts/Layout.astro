---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>SCVDA - Santa Clara Valley Darts Association</title>

		<!-- Google Fonts: Oswald & Inter -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Oswald:wght@400;500;600;700&display=swap" rel="stylesheet">
	</head>
	<body class="bg-background-white font-inter text-primary-black min-h-screen flex flex-col m-0 p-0">
		<Header />

		<main class="flex-grow max-w-7xl mx-auto w-full px-6 py-8">
			<slot />
		</main>

		<Footer />
	</body>
</html>