---
import Layout from '../layouts/Layout.astro';
---

<Layout>
	<div class="py-12 px-4 sm:px-6 lg:px-8 max-w-7xl mx-auto">

		<!-- Section 1: Introduction -->
		<section class="mb-16">
			<h1 class="text-4xl md:text-5xl font-oswald font-bold text-primary-black mb-6 border-b-4 border-accent-red pb-4 inline-block">
				About SCVDA
			</h1>
			<div class="text-lg md:text-xl font-inter text-gray-800 leading-relaxed max-w-4xl space-y-4">
				<p>
					Santa Clara Valley Darts Association (SCVDA) is a registered California Not-For-Profit organization which promotes the sport of steel-tipped darts in the southern part of the San Francisco Bay Area (AKA Silicon Valley). We run two seasons per year, usually running Feb-June and Aug-Dec. We currently play on Thursday nights, in pubs ranging from Campbell to Palo Alto.
				</p>
				<p>
					We welcome players of all skill levels, and currently have 3 skill divisions. See our <a href="/faq" class="text-accent-red hover:underline">FAQ page</a> for more.
				</p>
			</div>
		</section>

		<!-- Section 2: Get Involved -->
		<section class="mb-16">
			<h2 class="text-3xl md:text-4xl font-oswald font-bold text-primary-black mb-8 border-b-2 border-light-silver pb-2">
				Get Involved
			</h2>
			<div class="text-lg md:text-xl font-inter text-gray-800 leading-relaxed max-w-4xl space-y-4">
				<p>
					If you're interested in getting involved or want to share ideas/feedback/questions, please reach out to the Board at <a href="mailto:scvda-board@googlegroups.com" class="text-accent-red hover:underline">scvda-board@googlegroups.com</a> or contact a Board member directly! We have rotating committees for short-term projects (e.g. banquet planning committee, league merch committee, rules & bylaws committee) that are always open to new members.
				</p>
				<p>
					Also, our monthly Board meetings are open to the public. Generally, they are the second Monday of each month at 7pm PT at this link: <a href="https://meet.google.com/azb-wcea-mbr" target="_blank" rel="noopener noreferrer" class="text-accent-red hover:underline">https://meet.google.com/azb-wcea-mbr</a>
				</p>
			</div>
		</section>

		<!-- Section 3: Board & Leadership -->
		<section>
			<h2 class="text-3xl md:text-4xl font-oswald font-bold text-primary-black mb-8 border-b-2 border-light-silver pb-2">
				Board & Leadership
			</h2>

			<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">

				<!-- League Officers -->
				<div class="bg-white rounded-lg shadow-md border border-light-silver overflow-hidden">
					<div class="bg-primary-black text-white py-3 px-4">
						<h3 class="text-xl font-oswald font-semibold tracking-wide">League Officers</h3>
					</div>
					<div class="p-6 font-inter text-gray-800">
						<ul class="space-y-3">
							<li class="flex flex-col sm:flex-row sm:justify-between sm:items-baseline border-b border-gray-100 pb-2 last:border-0 last:pb-0">
								<span class="font-medium text-primary-black">John Penix</span>
								<span class="text-sm text-gray-500 italic">President</span>
							</li>
							<li class="flex flex-col sm:flex-row sm:justify-between sm:items-baseline border-b border-gray-100 pb-2 last:border-0 last:pb-0">
								<span class="font-medium text-primary-black">Veronica Cruz</span>
								<span class="text-sm text-gray-500 italic">Vice President</span>
							</li>
							<li class="flex flex-col sm:flex-row sm:justify-between sm:items-baseline border-b border-gray-100 pb-2 last:border-0 last:pb-0">
								<span class="font-medium text-primary-black">Saul Manzo</span>
								<span class="text-sm text-gray-500 italic">Secretary</span>
							</li>
							<li class="flex flex-col sm:flex-row sm:justify-between sm:items-baseline border-b border-gray-100 pb-2 last:border-0 last:pb-0">
								<span class="font-medium text-primary-black">Robin Gonzalez</span>
								<span class="text-sm text-gray-500 italic">Treasurer</span>
							</li>
							<li class="flex flex-col sm:flex-row sm:justify-between sm:items-baseline border-b border-gray-100 pb-2 last:border-0 last:pb-0">
								<span class="font-medium text-primary-black">Ross Davies</span>
								<span class="text-sm text-gray-500 italic">Competition Secretary</span>
							</li>
						</ul>
					</div>
				</div>

				<!-- Non-Voting Positions -->
				<div class="bg-white rounded-lg shadow-md border border-light-silver overflow-hidden">
					<div class="bg-accent-red text-white py-3 px-4">
						<h3 class="text-xl font-oswald font-semibold tracking-wide">Non-Voting Positions</h3>
					</div>
					<div class="p-6 font-inter text-gray-800">
						<ul class="space-y-3">
							<li class="flex flex-col sm:flex-row sm:justify-between sm:items-baseline border-b border-gray-100 pb-2 last:border-0 last:pb-0">
								<span class="font-medium text-primary-black">Saul Manzo</span>
								<span class="text-sm text-gray-500 italic">Social Media Manager</span>
							</li>
							<li class="flex flex-col sm:flex-row sm:justify-between sm:items-baseline border-b border-gray-100 pb-2 last:border-0 last:pb-0">
								<span class="font-medium text-primary-black">Russell van Tassell</span>
								<span class="text-sm text-gray-500 italic">Webmaster / Director</span>
							</li>
						</ul>
					</div>
				</div>

				<!-- League Representatives -->
				<div class="bg-white rounded-lg shadow-md border border-light-silver overflow-hidden md:col-span-2 lg:col-span-1">
					<div class="bg-light-silver text-primary-black py-3 px-4">
						<h3 class="text-xl font-oswald font-semibold tracking-wide">League Representatives</h3>
						<span class="text-xs uppercase tracking-wider text-gray-600">Spring 2026</span>
					</div>
					<div class="p-6 font-inter text-gray-800">
						<ul class="space-y-4">
							<li class="border-b border-gray-100 pb-3 last:border-0 last:pb-0">
								<div class="font-medium text-primary-black flex justify-between items-baseline mb-1">
									<span>Kevin Wieman</span>
									<span class="text-sm text-accent-red font-semibold">A-League Rep</span>
								</div>
							</li>
							<li class="border-b border-gray-100 pb-3 last:border-0 last:pb-0">
								<div class="font-medium text-primary-black flex justify-between items-baseline mb-1">
									<span>Carmen Whitney</span>
									<span class="text-sm text-accent-red font-semibold">B-League Rep</span>
								</div>
							</li>
							<li class="border-b border-gray-100 pb-3 last:border-0 last:pb-0">
								<div class="font-medium text-primary-black flex justify-between items-baseline mb-1">
									<span>Jason Apostle</span>
									<span class="text-sm text-accent-red font-semibold">C-League Rep</span>
								</div>
							</li>
						</ul>
					</div>
				</div>

			</div>
		</section>

	</div>
</Layout>
