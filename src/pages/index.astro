---
import Layout from '../layouts/Layout.astro';
---

<Layout>
	<div class="text-center py-20">
		<h1 class="text-5xl md:text-6xl font-oswald font-bold text-primary-black mb-6">
			Welcome to SCVDA
		</h1>
		<p class="text-xl md:text-2xl font-inter text-gray-700 mb-8 max-w-2xl mx-auto">
			The home of the Santa Clara Valley Darts Association. Join us for competitive dart leagues and events!
		</p>

		<div class="flex flex-col sm:flex-row justify-center gap-4">
			<a href="/about" class="px-8 py-3 bg-accent-red text-white font-oswald font-medium text-lg rounded hover:bg-red-800 transition-colors">
				Learn More
			</a>
			<a href="#" class="px-8 py-3 bg-light-silver text-primary-black font-oswald font-medium text-lg rounded hover:bg-gray-300 transition-colors">
				Join Now
			</a>
		</div>
	</div>
</Layout>