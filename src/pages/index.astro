---
import Layout from '../layouts/Layout.astro';
import announcements from '../data/announcements.json';

const recentAnnouncements = announcements
	.sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime())
	.slice(0, 5);
---

<Layout>
	<div class="py-12 px-4 sm:px-6 lg:px-8 max-w-7xl mx-auto">

		<!-- Section 1: Introduction -->
		<section class="mb-16">
			<h1 class="text-4xl md:text-5xl font-oswald font-bold text-primary-black mb-6 border-b-4 border-accent-red pb-4 inline-block">
				Welcome to SCVDA
			</h1>
			<p class="text-lg md:text-xl font-inter text-gray-800 leading-relaxed max-w-4xl">
				The SCVDA is a registered California Not-For-Profit organization which promotes the sport of steel-tipped darts in the southern part of the San Francisco Bay Area (AKA Silicon Valley). We run two seasons per year, usually beginning in February, and August. We currently have divisions playing on Thursday nights, in pubs ranging from Campbell to Palo Alto. The SCVDA is a member of the American Darts Organization.
			</p>
		</section>

		<!-- Section 2: Announcements -->
		<section class="mb-16">
			<h2 class="text-3xl md:text-4xl font-oswald font-bold text-primary-black mb-8 border-b-2 border-light-silver pb-2">
				Latest Announcements
			</h2>

			<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
				{recentAnnouncements.map((announcement, index) => (
					<div class="bg-white rounded-lg shadow-md border border-light-silver overflow-hidden">
						<div class={`${index % 2 === 0 ? 'bg-accent-red' : 'bg-light-silver'} ${index % 2 === 0 ? 'text-white' : 'text-primary-black'} py-3 px-4 flex justify-between items-center`}>
							<h3 class="text-xl font-oswald font-semibold tracking-wide">{announcement.title}</h3>
						</div>
						<div class="p-6 font-inter text-gray-800">
							<p class="text-sm text-gray-500 italic mb-3">
								{new Date(announcement.date).toLocaleDateString('en-US', {
									year: 'numeric',
									month: 'long',
									day: 'numeric'
								})}
							</p>
							<p class="leading-relaxed">{announcement.body}</p>
						</div>
					</div>
				))}
			</div>

			{announcements.length > 5 && (
				<div class="mt-8 text-center">
					<a href="/announcements-history" class="inline-block bg-primary-black hover:bg-gray-800 text-white font-oswald font-bold py-2 px-6 rounded transition-colors">
						See old announcements
					</a>
				</div>
			)}
		</section>

	</div>
</Layout>
