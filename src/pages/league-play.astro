---
import Layout from '../layouts/Layout.astro';
---

<Layout>
	<div class="py-12 px-4 sm:px-6 lg:px-8 max-w-7xl mx-auto">
		<section class="mb-16">
			<h1 class="text-4xl md:text-5xl font-oswald font-bold text-primary-black mb-6 border-b-4 border-accent-red pb-4 inline-block">
				League Play
			</h1>

			<p class="text-lg font-inter text-gray-800 mb-8">
				League play is largely managed through DartConnect. Here are some quick links to our league pages.
			</p>

			<div class="flex flex-wrap gap-4 mb-12 border-b border-light-silver pb-12">
				<a href="https://my.dartconnect.com/league/schedule/scvda/21709" target="_blank" rel="noopener noreferrer" class="inline-block bg-accent-red hover:bg-red-700 text-white font-oswald font-bold py-3 px-8 rounded-lg shadow-md transition-colors text-lg">
					View Schedule
				</a>
				<a href="https://tv.dartconnect.com/league/scvda/21709/standings" target="_blank" rel="noopener noreferrer" class="inline-block bg-primary-black hover:bg-gray-800 text-white font-oswald font-bold py-3 px-8 rounded-lg shadow-md transition-colors text-lg">
					View Standings
				</a>
			</div>

			<div class="space-y-12 max-w-3xl">
				<!-- Finding Substitutes -->
				<div class="font-inter">
					<h3 class="text-xl font-oswald font-bold text-primary-black mb-3 uppercase tracking-wide">Finding Substitutes</h3>
					<div class="text-gray-800 space-y-4">
						<p>
							Substitutes of equivalent skill level are allowed on league night. Substitutes must be approved by the opposing captain prior to the start of the match. After a sub has subbed for a team two times, that person must sign up as a team member and pay the membership fee before being eligible to play a third time with that same team.
						</p>
						<p>
							<a href="https://chat.whatsapp.com/E7PYCHAtQif9mWHdv5Zalq" target="_blank" rel="noopener noreferrer" class="text-accent-red hover:underline font-semibold">Join this WhatsApp group</a> if you're interested in being a sub OR if you're a captain looking for a sub!
						</p>
					</div>
				</div>

				<!-- Score Submission -->
				<div class="font-inter">
					<h3 class="text-xl font-oswald font-bold text-primary-black mb-3 uppercase tracking-wide">Submit Scores</h3>
					<p class="text-gray-800">
						Send a picture of paper scoresheet to <a href="mailto:scvda-results@googlegroups.com" class="text-accent-red hover:underline font-semibold">scvda-results@googlegroups.com</a> within 24 hours of match start time.
					</p>
				</div>

				<!-- Joining Info -->
				<div class="font-inter">
					<h3 class="text-xl font-oswald font-bold text-primary-black mb-3 uppercase tracking-wide">Interested in joining?</h3>
					<div class="text-gray-800 space-y-2">
						<p>Reach out to <a href="mailto:scvda-board@googlegroups.com" class="text-accent-red hover:underline font-semibold">scvda-board@googlegroups.com</a>!</p>
						<p>Our league has 3 divisions, with space for beginners to advanced players!</p>
					</div>
				</div>

				<!-- Rosters -->
				<div class="font-inter">
					<h3 class="text-xl font-oswald font-bold text-primary-black mb-3 uppercase tracking-wide">Rosters</h3>
					<div class="w-full h-[400px] border border-light-silver rounded-lg overflow-hidden shadow-sm">
						<iframe
							src="https://docs.google.com/spreadsheets/d/1iex_JY96SxJApB5DmfEJDU64NGtsZ__SUZXjPP6S750/preview"
							class="w-full h-full"
							style="border:0;"
							allowfullscreen=""
							loading="lazy"
						></iframe>
					</div>
				</div>
			</div>
		</section>
	</div>
</Layout>
