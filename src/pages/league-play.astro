---
import Layout from '../layouts/Layout.astro';
---

<Layout>
	<div class="py-12 px-4 sm:px-6 lg:px-8 max-w-7xl mx-auto">
		<section class="mb-16">
			<h1 class="text-4xl md:text-5xl font-oswald font-bold text-primary-black mb-6 border-b-4 border-accent-red pb-4 inline-block">
				League Play
			</h1>

			<div class="flex flex-wrap gap-4 mb-12">
				<a href="https://my.dartconnect.com/league/schedule/scvda/21709" target="_blank" rel="noopener noreferrer" class="inline-block bg-accent-red hover:bg-red-700 text-white font-oswald font-bold py-3 px-8 rounded-lg shadow-md transition-colors text-lg">
					View Schedule
				</a>
				<a href="https://tv.dartconnect.com/league/scvda/21709/standings" target="_blank" rel="noopener noreferrer" class="inline-block bg-primary-black hover:bg-gray-800 text-white font-oswald font-bold py-3 px-8 rounded-lg shadow-md transition-colors text-lg">
					View Standings
				</a>
			</div>

			<div class="grid grid-cols-1 md:grid-cols-2 gap-8">
				<!-- Score Submission Card -->
				<div class="bg-white rounded-lg shadow-md border border-light-silver overflow-hidden">
					<div class="bg-primary-black text-white py-3 px-4">
						<h3 class="text-xl font-oswald font-semibold tracking-wide">Submit Scores</h3>
					</div>
					<div class="p-6 font-inter text-gray-800">
						<p class="mb-4">Send a picture of paper scoresheet to <a href="mailto:scvda-results@googlegroups.com" class="text-accent-red hover:underline font-semibold">scvda-results@googlegroups.com</a> within 24 hours of match start time.</p>
					</div>
				</div>

				<!-- Joining Info Card -->
				<div class="bg-white rounded-lg shadow-md border border-light-silver overflow-hidden">
					<div class="bg-accent-red text-white py-3 px-4">
						<h3 class="text-xl font-oswald font-semibold tracking-wide">Interested in joining?</h3>
					</div>
					<div class="p-6 font-inter text-gray-800">
						<p class="mb-4">Reach out to <a href="mailto:scvda-board@googlegroups.com" class="text-accent-red hover:underline font-semibold">scvda-board@googlegroups.com</a>!</p>
						<p>Our league has 3 divisions, with space for beginners to advanced players!</p>
					</div>
				</div>
			</div>
		</section>
	</div>
</Layout>
